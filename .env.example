# ============================================================
# Supabase — powers the admin (orders, products, offers, hero) + receipt uploads
# Get these from your Supabase project: Settings → API
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only (Settings → API → service_role secret). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated emails allowed into /admin (leave empty to allow any signed-in user)
ADMIN_EMAILS=

# Optional: your production URL
NEXT_PUBLIC_SITE_URL=https://ruabyfresh.vercel.app

# The site works WITHOUT these (it falls back to built-in defaults and
# WhatsApp-only orders). Add them to switch the admin + order storage on.
